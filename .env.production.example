# ⚠️ Configure estas variáveis no Dashboard da Vercel
# Settings → Environment Variables

# 🔴 OBRIGATÓRIO: URL do backend (sem / no final)
# Exemplo com Render:
NEXT_PUBLIC_API_URL=https://artistlog-backend-latest.onrender.com

# ✅ Opcionais (já têm defaults no código)
NEXT_PUBLIC_ENABLE_REAL_TIME=true
NEXT_PUBLIC_ENABLE_WEBSOCKET=true

# 🌍 Geocoding APIs (públicas, já configuradas como default)
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org
NEXT_PUBLIC_BIGDATACLOUD_URL=https://api.bigdatacloud.net/data/reverse-geocode-client

# 📊 Analytics (opcional)
NEXT_PUBLIC_ANALYTICS_ID=

# 📝 Notas:
# - Não commite este arquivo com valores reais
# - Configure na Vercel: Project Settings → Environment Variables
# - Aplique para: Production, Preview e Development
