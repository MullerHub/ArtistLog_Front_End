# Frontend API
# Main API URL used by the app in both dev and production when defined.
VITE_API_URL=

# Optional local and production fallbacks used by src/lib/api-client.ts.
VITE_LOCAL_API_URL=http://localhost:8080
VITE_PROD_API_FALLBACK_URL=https://artistlog-backend-latest.onrender.com

# Vite dev server (optional)
VITE_HOST=::
VITE_PORT=8080

# E2E (Playwright) options
# If E2E_BASE_URL is set, Playwright will not start a local webServer.
E2E_BASE_URL=
E2E_HOST=127.0.0.1
E2E_PORT=5173

# Optional API URL override used by e2e/helpers/session.ts mock routes.
E2E_API_URL=
